{
  "name": "safebank-ai",
  "private": true,
  "scripts": {
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "tsx scripts/reset-db.ts",
    "dev:web": "cd frontend && npx pnpm dev",
    "dev:api": "cd backend && python -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "dev": "concurrently \"pnpm dev:api\" \"pnpm dev:web\""
  },
  "devDependencies": {
    "@prisma/client": "^6.8.2",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.2",
    "concurrently": "^9.1.2",
    "prisma": "^6.8.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
